rules_version = '2';
// MEEZAN Storage rules.
// verification/{uid}/... : lawyer syndicate card uploads (owner writes, owner+admin read)
// vault/{uid}/...        : client document vault (owner full access; sharing is done
//                          via long-lived download URLs stored in Firestore /documents,
//                          which the app only reveals to users in sharedWith).
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() { return request.auth != null && request.auth.token.admin == true; }

    match /verification/{uid}/{file} {
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024;
      allow read:  if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }

    match /vault/{uid}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 25 * 1024 * 1024;
      allow read:  if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
  }
}
